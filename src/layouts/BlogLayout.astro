---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    author: string;
    tags?: string[];
  };
}

const { frontmatter } = Astro.props;
const dateStr = new Date(frontmatter.pubDate).toLocaleDateString('pl-PL', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <article class="post-container">
    <header class="post-header">
      <div class="container">
        {frontmatter.tags && <div class="tags">{frontmatter.tags.map(t => <span class="tag">{t}</span>)}</div>}
        <h1>{frontmatter.title}</h1>
        <p class="post-meta">{dateStr} · {frontmatter.author}</p>
        <p class="post-desc">{frontmatter.description}</p>
      </div>
    </header>
    <div class="post-body container">
      <slot />
    </div>
  </article>
</Layout>

<style>
.post-container { padding: 2rem 0 4rem; }
.post-header { background: var(--navy-light); border-bottom: 1px solid var(--gold); padding: 3rem 0 2rem; margin-bottom: 2rem; }
.post-header h1 { font-size: clamp(1.8rem, 4vw, 3rem); color: var(--gold); margin: 0.5rem 0; }
.tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
.tag { background: var(--gold); color: var(--navy); padding: 0.2rem 0.6rem; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; }
.post-meta { color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem; }
.post-desc { color: var(--gold-light); font-style: italic; font-size: 1.05rem; }
.post-body { max-width: 780px; }
.post-body :global(h2) { color: var(--gold); margin: 2rem 0 0.75rem; font-size: 1.6rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
.post-body :global(h3) { color: var(--gold-light); margin: 1.5rem 0 0.5rem; }
.post-body :global(p) { margin-bottom: 1.25rem; line-height: 1.8; }
.post-body :global(a) { color: var(--gold); border-bottom: 1px dotted var(--gold); }
</style>
