---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Artykuły — OZE Warszawa">
  <div class="container">
    <header class="page-header">
      <h1>Wszystkie artykuły</h1>
      <p>Wiedza o OZE w Warszawie i na Mazowszu — {posts.length} artykułów</p>
    </header>

    {posts.length > 0 ? (
      <div class="posts-grid">
        {posts.map(post => (
          <PostCard title={post.data.title} description={post.data.description} slug={post.slug} pubDate={post.data.pubDate} tags={post.data.tags} />
        ))}
      </div>
    ) : (
      <p class="empty-state">Artykuły pojawią się wkrótce. Zapraszamy!</p>
    )}
  </div>
</Layout>

<style>
.page-header { padding: 3rem 0 2rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
.page-header h1 { font-size: 2.5rem; color: var(--gold); margin-bottom: 0.5rem; }
.page-header p { color: var(--text-muted); }
.posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; padding-bottom: 3rem; }
.empty-state { text-align: center; padding: 4rem 0; color: var(--text-muted); font-size: 1.1rem; }
</style>
