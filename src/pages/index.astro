---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = posts.slice(0, 1);
const recent = posts.slice(1, 7);
---

<Layout title="Strona główna — OZE Warszawa">
  <section class="hero">
    <div class="container">
      <h1>OZE w Warszawie i na Mazowszu</h1>
      <p>Najświeższe informacje o odnawialnych źródłach energii, fotowoltaice, pompach ciepła i zielonym budownictwie w regionie warszawskim.</p>
    </div>
  </section>

  {featured.length > 0 ? (
    <section class="featured-section container">
      <h2 class="section-title">Wyróżniony artykuł</h2>
      <div class="featured-post">
        <span class="featured-tag">POLECAMY</span>
        <h2><a href={`/blog/${featured[0].slug}`}>{featured[0].data.title}</a></h2>
        <p>{featured[0].data.description}</p>
        <a href={`/blog/${featured[0].slug}`} class="btn-primary">Czytaj artykuł →</a>
      </div>
    </section>
  ) : (
    <section class="container coming-soon">
      <p>📡 Pierwsze artykuły już wkrótce. Śledź nas!</p>
    </section>
  )}

  {recent.length > 0 && (
    <section class="posts-section container">
      <h2 class="section-title">Najnowsze artykuły</h2>
      <div class="posts-grid">
        {recent.map(post => (
          <PostCard title={post.data.title} description={post.data.description} slug={post.slug} pubDate={post.data.pubDate} tags={post.data.tags} />
        ))}
      </div>
      <div class="all-posts">
        <a href="/blog" class="btn-outline">Wszystkie artykuły →</a>
      </div>
    </section>
  )}
</Layout>

<style>
.hero { background: linear-gradient(135deg, var(--navy-light) 0%, #0d2040 100%); border-bottom: 2px solid var(--gold); padding: 4rem 0; margin-bottom: 3rem; }
.hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); color: var(--gold); margin-bottom: 1rem; }
.hero p { font-size: 1.1rem; color: var(--text-muted); max-width: 600px; }
.section-title { font-family: 'Playfair Display', serif; color: var(--gold); border-bottom: 1px solid var(--border); padding-bottom: 0.75rem; margin-bottom: 1.5rem; font-size: 1.5rem; }
.featured-post { background: var(--navy-light); border: 1px solid var(--gold); padding: 2.5rem; margin-bottom: 3rem; }
.featured-tag { background: var(--gold); color: var(--navy); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.6rem; display: inline-block; margin-bottom: 1rem; }
.featured-post h2 { font-size: 2rem; margin-bottom: 0.75rem; }
.featured-post h2 a { color: var(--text); }
.featured-post h2 a:hover { color: var(--gold); }
.featured-post p { color: var(--text-muted); font-size: 1.05rem; margin-bottom: 1.5rem; }
.btn-primary { background: var(--gold); color: var(--navy); padding: 0.7rem 1.5rem; font-weight: 700; display: inline-block; }
.btn-primary:hover { background: var(--gold-light); text-decoration: none; }
.posts-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; margin-bottom: 2rem; }
.all-posts { text-align: center; margin-top: 1rem; }
.btn-outline { border: 2px solid var(--gold); color: var(--gold); padding: 0.6rem 1.5rem; display: inline-block; }
.btn-outline:hover { background: var(--gold); color: var(--navy); text-decoration: none; }
.coming-soon { padding: 3rem 0; text-align: center; color: var(--text-muted); font-size: 1.1rem; }
.featured-section { margin-bottom: 1rem; }
.posts-section { padding-bottom: 3rem; }
</style>
